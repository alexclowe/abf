{
  "name": "abf",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.28.1",
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "test": "turbo test",
    "typecheck": "turbo typecheck",
    "lint": "biome lint .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "clean": "turbo clean",
    "abf": "node packages/cli/dist/index.js",
    "quickstart": "pnpm install && pnpm build && pnpm start",
    "start": "node packages/cli/dist/index.js dev",
    "start:ollama": "node packages/cli/dist/index.js dev --provider ollama"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@biomejs/biome",
      "esbuild",
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.0",
    "turbo": "^2.4.0",
    "typescript": "^5.8.0"
  }
}
