{
	"$schema": "https://biomejs.dev/schemas/1.9.0/schema.json",
	"organizeImports": {
		"enabled": true
	},
	"linter": {
		"enabled": true,
		"rules": {
			"recommended": true,
			"correctness": {
				"noUnusedImports": "error",
				"noUnusedVariables": "warn",
				"useExhaustiveDependencies": "warn"
			},
			"style": {
				"noNonNullAssertion": "off",
				"noUnusedTemplateLiteral": "off",
				"useTemplate": "off",
				"useImportType": "warn",
				"useConst": "error"
			},
			"suspicious": {
				"noExplicitAny": "off",
				"noImplicitAnyLet": "off",
				"noArrayIndexKey": "off",
				"noControlCharactersInRegex": "off"
			},
			"complexity": {
				"noBannedTypes": "off",
				"useLiteralKeys": "off"
			},
			"performance": {
				"noDelete": "off"
			},
			"a11y": {
				"useButtonType": "warn",
				"noLabelWithoutControl": "off",
				"useKeyWithClickEvents": "off",
				"noAutofocus": "off"
			}
		}
	},
	"formatter": {
		"enabled": true,
		"indentStyle": "tab",
		"lineWidth": 100
	},
	"javascript": {
		"formatter": {
			"quoteStyle": "single",
			"semicolons": "always",
			"trailingCommas": "all"
		}
	},
	"files": {
		"ignore": ["**/dist/**", "**/node_modules/**", "**/.next/**", "**/*.json"]
	}
}
