# ──────────────────────────────────────────────────────────────────────
# ABF Environment Variables
# Copy this file to .env and fill in your values.
# ──────────────────────────────────────────────────────────────────────

# ── LLM Provider (at least one required) ─────────────────────────────

# Anthropic Claude (recommended)
# Get your key at: https://console.anthropic.com/keys
ANTHROPIC_API_KEY=sk-ant-...

# OpenAI GPT (alternative)
# Get your key at: https://platform.openai.com/api-keys
# OPENAI_API_KEY=sk-...

# Ollama — free, runs locally, no key needed
# OLLAMA_BASE_URL=http://localhost:11434

# ── Security ──────────────────────────────────────────────────────────

# Protect the API — set this when deploying to the cloud
# If not set, the API is open (fine for local development)
# ABF_API_KEY=your-secret-key-here

# Restrict CORS to your dashboard domain (comma-separated)
# Defaults to localhost:3000 and localhost:3001
# ABF_CORS_ORIGINS=https://your-dashboard.vercel.app,http://localhost:3001

# ── Storage (optional — defaults to filesystem) ───────────────────────

# PostgreSQL — recommended for production
# Railway auto-injects DATABASE_URL when you add a Postgres addon
# DATABASE_URL=postgresql://user:pass@host:5432/dbname

# ── Message Bus (optional — defaults to in-process) ──────────────────

# Redis — recommended for production multi-agent workflows
# Railway auto-injects REDIS_URL when you add a Redis addon
# REDIS_URL=redis://user:pass@host:6379

# ── Runtime ───────────────────────────────────────────────────────────

NODE_ENV=production
PORT=3000
