    "linkedom": "^0.18.12",
    "marked": "^17.0.3",
    "nanoid": "^5.1.0",
    "nodemailer": "^8.0.1",
    "openai": "^6.24.0",
    "pg": "^8.18.0",
    "pino": "^9.6.0",
    "playwright-core": "^1.58.2",
    "yaml": "^2.7.0",
    "zod": "^3.24.0"
