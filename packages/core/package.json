    "@types/better-sqlite3": "^7.6.13",
    "@types/ioredis-mock": "^8.2.6",
    "@types/marked": "^6.0.0",
    "@types/node": "^20.17.0",
    "@types/nodemailer": "^7.0.11",

    "@types/pg": "^8.16.0",
    "@vitest/coverage-v8": "^3.1.0",
    "ioredis-mock": "^8.13.1",
    "tsup": "^8.4.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
