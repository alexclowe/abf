    "@resvg/resvg-js": "^2.6.2",
    "better-sqlite3": "^12.6.2",
    "croner": "^10.0.1",
    "hono": "^4.12.2",
    "ioredis": "^5.9.3",
    "linkedom": "^0.18.12",
    "mammoth": "^1.11.0",
    "marked": "^17.0.3",
    "nanoid": "^5.1.0",
    "nodemailer": "^8.0.1",
    "openai": "^6.24.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.18.0",
    "pino": "^9.6.0",
    "playwright-core": "^1.58.2",
    "resend": "^4.1.2",
    "satori": "^0.12.1",
    "sharp": "^0.34.1",
    "stripe": "^17.7.0",
    "yaml": "^2.8.3",
    "zod": "^3.24.0"
  },
