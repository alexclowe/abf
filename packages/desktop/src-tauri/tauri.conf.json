{
  "$schema": "https://raw.githubusercontent.com/nicegui-community/nicetauri/refs/heads/main/nicetauri/tauri.conf.schema.json",
  "productName": "ABF Desktop",
  "version": "1.0.0",
  "identifier": "dev.abf.desktop",
  "build": {
    "beforeDevCommand": "",
    "devUrl": "http://localhost:3001",
    "beforeBuildCommand": "",
    "frontendDist": "../dist"
  },
  "app": {
    "title": "ABF — Agentic Business Framework",
    "windows": [
      {
        "title": "ABF Dashboard",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "menuOnLeftClick": false,
      "tooltip": "ABF — AI Agent Team"
    },
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "macOS": {
      "frameworks": [],
      "minimumSystemVersion": "10.15"
    },
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": ""
    }
  }
}
